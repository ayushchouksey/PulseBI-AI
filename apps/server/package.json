{
  "name": "@pulsebi/server",
  "version": "1.0.0",
  "private": true,
  "description": "Backend API for PulseBI AI",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@pulsebi/shared-config": "workspace:*",
    "@pulsebi/shared-types": "workspace:*",
    "@pulsebi/shared-utils": "workspace:*",
    "arquero": "^8.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "multer": "^2.2.0",
    "papaparse": "^5.5.4",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.0",
    "@types/papaparse": "^5.5.2",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}