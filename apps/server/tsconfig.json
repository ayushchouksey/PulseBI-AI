{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": "dist",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@pulsebi/shared-types": ["../../packages/shared-types/src"],
      "@pulsebi/shared-utils": ["../../packages/shared-utils/src"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
