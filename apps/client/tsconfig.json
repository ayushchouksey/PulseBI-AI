{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@pulsebi/shared-types": ["../../packages/shared-types/src"],
      "@pulsebi/shared-utils": ["../../packages/shared-utils/src"]
    },
    "baseUrl": "."
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
